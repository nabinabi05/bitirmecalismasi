FROM python:3.12-slim

WORKDIR /app

COPY requirements_gateway.txt .
RUN pip install --no-cache-dir -r requirements_gateway.txt

COPY gateway_api.py .

# Cloud Run, dinlenecek portu PORT ortam değişkeniyle verir (varsayılan 8080)
ENV PORT=8000
CMD exec uvicorn gateway_api:app --host 0.0.0.0 --port ${PORT}
